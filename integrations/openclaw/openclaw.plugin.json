{
  "id": "plugin.vmga",
  "name": "VMGA Mail Governance",
  "description": "OpenClaw plugin facade for VMGA-governed mailbox actions.",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "broker_url": {
        "type": "string",
        "format": "uri"
      },
      "broker_timeout_seconds": {
        "type": "number",
        "minimum": 1,
        "maximum": 120
      },
      "action_map": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      }
    },
    "required": ["broker_url"],
    "additionalProperties": false
  }
}
