{
  "name": "openclaw-plugin-vmga",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "plugin:build": "npm run build && openclaw plugins build --root . --entry ./dist/index.js",
    "plugin:validate": "npm run build && openclaw plugins validate --root . --entry ./dist/index.js",
    "test": "vitest run src"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.6.5"
  },
  "dependencies": {
    "typebox": "^1.2.8"
  },
  "devDependencies": {
    "openclaw": "latest",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
